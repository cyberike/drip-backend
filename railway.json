{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "python -c \"import os, subprocess; subprocess.run(['uvicorn', 'server:app', '--host', '0.0.0.0', '--port', os.environ.get('PORT', '8000')])\"",
    "healthcheckPath": "/api/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
